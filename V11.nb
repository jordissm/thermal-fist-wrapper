Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Create", " ", "convex", " ", "hulls"}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"chmCopper", "=", 
     RowBox[{"ConvexHullMesh", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Select", "[", 
         RowBox[{"dataCopper", ",", 
          RowBox[{
           RowBox[{
            RowBox[{"#", "[", 
             RowBox[{"[", "12", "]"}], "]"}], "<", 
            RowBox[{"minChi2Copper", "+", "1"}]}], "&"}]}], "]"}], "/.", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
          "T_", ",", "\[Mu]B_", ",", "\[Mu]S_", ",", "\[Mu]Q_", ",", "nB_", 
           ",", "nS_", ",", "nQ_", ",", "baryonDensityOverChargeDensity_", 
           ",", "energyDensity_", ",", "entropyDensity_", ",", 
           "entropyDensityOverBaryonDensity_", ",", "chi2_", ",", 
           "chi2OverNdof_"}], "}"}], "->", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"\[Mu]B", "/", "T"}], ",", "\[Mu]Q"}], "}"}]}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"MeshCellStyle", "->", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"1", "->", "Red"}], ",", 
          RowBox[{"2", "->", 
           RowBox[{"Opacity", "[", 
            RowBox[{"0.1", ",", "Red"}], "]"}]}]}], "}"}]}]}], "]"}]}], ";"}],
    "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"chmGold", "=", 
     RowBox[{"ConvexHullMesh", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Select", "[", 
         RowBox[{"dataGold", ",", 
          RowBox[{
           RowBox[{
            RowBox[{"#", "[", 
             RowBox[{"[", "12", "]"}], "]"}], "<", 
            RowBox[{"minChi2Gold", "+", "1"}]}], "&"}]}], "]"}], "/.", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
          "T_", ",", "\[Mu]B_", ",", "\[Mu]S_", ",", "\[Mu]Q_", ",", "nB_", 
           ",", "nS_", ",", "nQ_", ",", "baryonDensityOverChargeDensity_", 
           ",", "energyDensity_", ",", "entropyDensity_", ",", 
           "entropyDensityOverBaryonDensity_", ",", "chi2_", ",", 
           "chi2OverNdof_"}], "}"}], "->", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"\[Mu]B", "/", "T"}], ",", "\[Mu]Q"}], "}"}]}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"MeshCellStyle", "->", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"1", "->", "Blue"}], ",", 
          RowBox[{"2", "->", 
           RowBox[{"Opacity", "[", 
            RowBox[{"0.1", ",", "Blue"}], "]"}]}]}], "}"}]}]}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"chmUranium", "=", 
     RowBox[{"ConvexHullMesh", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Select", "[", 
         RowBox[{"dataUranium", ",", 
          RowBox[{
           RowBox[{
            RowBox[{"#", "[", 
             RowBox[{"[", "12", "]"}], "]"}], "<", 
            RowBox[{"minChi2Uranium", "+", "1"}]}], "&"}]}], "]"}], "/.", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
          "T_", ",", "\[Mu]B_", ",", "\[Mu]S_", ",", "\[Mu]Q_", ",", "nB_", 
           ",", "nS_", ",", "nQ_", ",", "baryonDensityOverChargeDensity_", 
           ",", "energyDensity_", ",", "entropyDensity_", ",", 
           "entropyDensityOverBaryonDensity_", ",", "chi2_", ",", 
           "chi2OverNdof_"}], "}"}], "->", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"\[Mu]B", "/", "T"}], ",", "\[Mu]Q"}], "}"}]}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"MeshCellStyle", "->", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"1", "->", "Green"}], ",", 
          RowBox[{"2", "->", 
           RowBox[{"Opacity", "[", 
            RowBox[{"0.1", ",", "Green"}], "]"}]}]}], "}"}]}]}], "]"}]}], 
    ";"}]}]}]], "Input",
 CellChangeTimes->{{3.969015912252435*^9, 3.969015922401394*^9}, {
