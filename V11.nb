  FormBox[
   RowBox[{"{", 
    RowBox[{"T", ",", 
     SubscriptBox["\[Mu]", "B"], ",", 
     SubscriptBox["\[Mu]", "Q"]}], "}"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "d4f3d9a9-e973-4e29-b7bc-3bc11d0c9dd9"],
